# Local development example.
# Copy to backend/.env and adjust values if needed.

APP__NAME=p2p-planner-backend
APP__ENV=local
APP__HOST=127.0.0.1
APP__PORT=18080
APP__LOG_FORMAT=pretty

DATABASE__URL=postgres://postgres:postgres@127.0.0.1:5432/p2p_planner
DATABASE__MAX_CONNECTIONS=20
DATABASE__MIN_CONNECTIONS=1
DATABASE__CONNECT_TIMEOUT_SECS=5

HTTP__BODY_LIMIT_MB=4
HTTP__CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

AUTH__JWT_SECRET=change-me-local-dev-secret
AUTH__PREVIOUS_JWT_SECRETS=
AUTH__ACCESS_TOKEN_TTL_MINUTES=15
AUTH__REFRESH_TOKEN_TTL_DAYS=30
AUTH__PUBLIC_SIGNUP_ENABLED=true
AUTH__REFRESH_COOKIE_NAME=p2p_planner_refresh
AUTH__DEVICE_COOKIE_NAME=p2p_planner_device
AUTH__COOKIE_SAME_SITE=lax
AUTH__COOKIE_SECURE=false
AUTH__ENABLE_DEV_HEADER_AUTH=false
AUTH__AUTH_RATE_LIMIT_WINDOW_SECS=60
AUTH__AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
AUTH__SENSITIVE_RATE_LIMIT_WINDOW_SECS=60
AUTH__SENSITIVE_RATE_LIMIT_MAX_ATTEMPTS=60
